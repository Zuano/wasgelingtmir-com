---
// Layout für statische Seiten (Impressum, Über mich etc.) / layout for static pages
import type { CollectionEntry } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FormattedDate from "~/components/FormattedDate.astro";

interface Props {
  page: CollectionEntry<"pages">;
}

const { page } = Astro.props;
const { data } = page;
---

<BaseLayout title={data.title} description={data.description}>
  <article class="mx-auto max-w-3xl px-4 py-10 md:px-6 md:py-16">
    <header class="mb-10">
      <h1 class="font-serif text-3xl font-bold tracking-tight text-stone-900 md:text-5xl dark:text-stone-50">
        {data.title}
      </h1>
      {data.description && (
        <p class="mt-4 text-lg text-stone-600 dark:text-stone-400">
          {data.description}
        </p>
      )}
      {data.updatedDate && (
        <p class="mt-2 text-sm text-stone-500 dark:text-stone-500">
          Aktualisiert: <FormattedDate date={data.updatedDate} />
        </p>
      )}
    </header>
    <div class="prose-article">
      <slot />
    </div>
  </article>
</BaseLayout>
