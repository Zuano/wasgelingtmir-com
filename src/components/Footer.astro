---
import { SITE, CATEGORIES } from "~/consts";
const year = new Date().getFullYear();
---

<footer
  class="mt-20 border-t border-stone-200 bg-stone-50 py-12 dark:border-stone-800 dark:bg-stone-900"
>
  <div class="mx-auto grid max-w-6xl gap-10 px-4 md:grid-cols-4 md:px-6">
    <div class="md:col-span-2">
      <p class="font-serif text-xl font-semibold text-stone-900 dark:text-stone-50">
        {SITE.title}
      </p>
      <p class="mt-2 max-w-md text-sm leading-relaxed text-stone-600 dark:text-stone-400">
        {SITE.description}
      </p>
    </div>

    <div>
      <h2 class="text-xs font-semibold tracking-wider text-stone-500 uppercase dark:text-stone-500">
        Kategorien
      </h2>
      <ul class="mt-3 space-y-2">
        {Object.values(CATEGORIES).map((cat) => (
          <li>
            <a
              href={`/kategorie/${cat.slug}`}
              class="text-sm text-stone-700 transition hover:text-brand-700 dark:text-stone-300 dark:hover:text-brand-300"
            >
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h2 class="text-xs font-semibold tracking-wider text-stone-500 uppercase dark:text-stone-500">
        Mehr
      </h2>
      <ul class="mt-3 space-y-2">
        <li>
          <a
            href="/blog"
            class="text-sm text-stone-700 transition hover:text-brand-700 dark:text-stone-300 dark:hover:text-brand-300"
          >
            Alle Artikel
          </a>
        </li>
        <li>
          <a
            href="/ueber-mich"
            class="text-sm text-stone-700 transition hover:text-brand-700 dark:text-stone-300 dark:hover:text-brand-300"
          >
            Über diese Seite
          </a>
        </li>
        <li>
          <a
            href="/impressum"
            class="text-sm text-stone-700 transition hover:text-brand-700 dark:text-stone-300 dark:hover:text-brand-300"
          >
            Impressum
          </a>
        </li>
        <li>
          <a
            href="/rss.xml"
            class="text-sm text-stone-700 transition hover:text-brand-700 dark:text-stone-300 dark:hover:text-brand-300"
          >
            RSS-Feed
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="mx-auto mt-10 max-w-6xl border-t border-stone-200 px-4 pt-6 md:px-6 dark:border-stone-800">
    <p class="text-xs text-stone-500 dark:text-stone-500">
      © {year} {SITE.author} · Mit Liebe gebaut in Österreich · Gehostet auf GitHub Pages
    </p>
  </div>
</footer>
