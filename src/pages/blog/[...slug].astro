---
// Einzelner Artikel / single blog post
import { getCollection, render } from "astro:content";
import BlogPostLayout from "~/layouts/BlogPostLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  // Nach Datum sortieren (neueste zuerst) / sort by date, newest first
  const sorted = posts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );
  return sorted.map((post, idx) => ({
    params: { slug: post.data.slug ?? post.id.replace(/\.md$/, "") },
    props: {
      post,
      prev: sorted[idx + 1],
      next: sorted[idx - 1],
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<BlogPostLayout post={post} prev={prev} next={next}>
  <Content />
</BlogPostLayout>
