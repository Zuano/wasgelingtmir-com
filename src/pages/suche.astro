---
// Suchseite mit Pagefind / search page using Pagefind
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Suche"
  description="Durchsuche alle Artikel auf wasgelingtmir.com."
>
  <section class="mx-auto max-w-3xl px-4 py-12 md:px-6 md:py-16">
    <header class="mb-8">
      <h1 class="font-serif text-4xl font-bold tracking-tight text-stone-900 md:text-5xl dark:text-stone-50">
        Suche
      </h1>
      <p class="mt-4 text-lg text-stone-600 dark:text-stone-400">
        Finde schnell den Artikel, den du suchst. Die Suche läuft komplett in deinem Browser – keine Server-Anfragen.
      </p>
    </header>

    <div id="search"></div>

    <noscript>
      <p class="rounded-lg border border-amber-300 bg-amber-50 p-4 text-amber-900">
        Die Suche benötigt JavaScript. Alternativ findest du alle Artikel auf der <a href="/blog" class="underline">Übersichtsseite</a>.
      </p>
    </noscript>
  </section>
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    // @ts-expect-error Pagefind wird erst zur Build-Zeit erzeugt / built at compile time
    new PagefindUI({
      element: "#search",
      showSubResults: true,
      showImages: false,
      translations: {
        placeholder: "Wonach suchst du?",
        clear_search: "Zurücksetzen",
        load_more: "Mehr Ergebnisse laden",
        search_label: "Suche",
        filters_label: "Filter",
        zero_results: "Keine Ergebnisse für [SEARCH_TERM]",
        many_results: "[COUNT] Ergebnisse für [SEARCH_TERM]",
        one_result: "[COUNT] Ergebnis für [SEARCH_TERM]",
        alt_search: "Keine Ergebnisse für [SEARCH_TERM]. Stattdessen [DIFFERENT_TERM]",
        search_suggestion: "Keine Ergebnisse für [SEARCH_TERM]. Versuch eines davon:",
        searching: "Suche nach [SEARCH_TERM]..."
      }
    });
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.95;
    --pagefind-ui-primary: var(--color-brand-600, #de5815);
    --pagefind-ui-text: #1c1917;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e7e5e4;
    --pagefind-ui-tag: #f5f5f4;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.75rem;
    --pagefind-ui-image-border-radius: 0.5rem;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-sans, system-ui);
  }

  :where([data-theme="dark"]) {
    --pagefind-ui-text: #fafaf9;
    --pagefind-ui-background: #0c0a09;
    --pagefind-ui-border: #292524;
    --pagefind-ui-tag: #1c1917;
  }
</style>
