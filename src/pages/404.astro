---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Seite nicht gefunden"
  description="Die gesuchte Seite existiert leider nicht."
  noindex
>
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-20 text-center md:px-6 md:py-32">
    <p class="text-7xl font-bold text-brand-600 dark:text-brand-400">404</p>
    <h1 class="mt-4 font-serif text-3xl font-bold tracking-tight text-stone-900 md:text-5xl dark:text-stone-50">
      Diese Seite ist verschollen
    </h1>
    <p class="mt-4 text-lg text-stone-600 dark:text-stone-400">
      Vielleicht wurde sie umgezogen, gelöscht – oder hat es nie gegeben. Schau doch mal auf der Startseite oder im Archiv vorbei.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700"
      >
        Zur Startseite
      </a>
      <a
        href="/blog"
        class="inline-flex items-center gap-2 rounded-lg border border-stone-300 bg-white px-5 py-2.5 text-sm font-semibold text-stone-800 transition hover:bg-stone-50 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-100 dark:hover:bg-stone-800"
      >
        Alle Artikel
      </a>
    </div>
  </section>
</BaseLayout>
